---
// src/layouts/BaseLayout.astro
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Full Stack & AI Systems Engineer" } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-[#030712] text-slate-100 scroll-smooth scroll-pt-15">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <meta name="generator" content={Astro.generator} />

    <title>Irfan Khattak | Full-Stack Developer</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.irfankhattak.com/" />
    <meta property="og:site_name" content="Irfan Khattak" />
    <meta property="og:title" content="Irfan Khattak | Full-Stack Developer" />
    <meta property="og:description" content={description} />
    <link rel="canonical" href="https://www.irfankhattak.com/" />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Irfan Khattak",
        "url": "https://www.irfankhattak.com/"
      }
    </script>

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B6W09Y5HF6"
    ></script>
    <script>
      // @ts-nocheck
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-B6W09Y5HF6");
    </script>
  </head>
  <body
    class="min-h-screen flex flex-col antialiased relative selection:bg-cyan-500/30 selection:text-cyan-200 overflow-x-hidden overflow-y-scroll"
  >
    <div class="hidden md:block fixed inset-0 z-[-1] pointer-events-none">
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-20 animate-grid-flow"
      >
      </div>
    </div>
  </body>

  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[500px] bg-radial from-cyan-500/10 via-transparent to-transparent pointer-events-none z-0"
  >
  </div>

  <header
    class="relative md:fixed top-0 left-0 w-full z-50 bg-[#030712]/80 backdrop-blur-md border-b border-slate-800/50 transition-all duration-300"
  >
    <div
      class="w-full max-w-6xl mx-auto px-6 py-4 md:py-6 flex justify-between items-center"
    >
      <a href="/" class="relative flex items-center group">
        <div class="flex -space-x-2">
          <div
            class="w-8 h-8 rounded-lg bg-white/10 border border-white/30 flex items-center justify-center backdrop-blur-md z-10 group-hover:-translate-y-1 transition-transform shadow-[0_0_15px_rgba(255,255,255,0.05)]"
          >
            <span class="text-sm font-black text-white font-sans">I</span>
          </div>
          <div
            class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center backdrop-blur-md translate-y-2 group-hover:translate-y-1 transition-transform shadow-[0_0_15px_rgba(255,255,255,0.02)]"
          >
            <span class="text-sm font-black text-slate-300 font-sans">K</span>
          </div>
        </div>
      </a>
      <nav class="hidden md:flex items-center gap-8">
        <a
          href="/"
          class="relative py-1 text-sm font-medium text-slate-300 hover:text-white transition-colors after:absolute after:-bottom-0.5 after:left-0 after:h-[2px] after:w-0 hover:after:w-full after:bg-cyan-400 after:transition-all after:duration-300"
          >Home</a
        >
        <a
          href="/#about"
          class="relative py-1 text-sm font-medium text-slate-300 hover:text-white transition-colors after:absolute after:-bottom-0.5 after:left-0 after:h-[2px] after:w-0 hover:after:w-full after:bg-cyan-400 after:transition-all after:duration-300"
          >About</a
        >
        <a
          href="/#projects"
          class="relative py-1 text-sm font-medium text-slate-300 hover:text-white transition-colors after:absolute after:-bottom-0.5 after:left-0 after:h-[2px] after:w-0 hover:after:w-full after:bg-cyan-400 after:transition-all after:duration-300"
          >Projects</a
        >
        <a
          href="/#contact"
          class="relative py-1 text-sm font-medium text-slate-300 hover:text-white transition-colors after:absolute after:-bottom-0.5 after:left-0 after:h-[2px] after:w-0 hover:after:w-full after:bg-cyan-400 after:transition-all after:duration-300"
          >Contact</a
        >

        <a
          href="/#contact"
          class="inline-flex items-center justify-center h-[34px] px-5 text-sm font-medium rounded-full bg-cyan-500/10 text-cyan-400 border border-cyan-500/30 hover:bg-cyan-500/20 hover:-translate-y-0.5 transition-all shadow-sm ml-4"
        >
          Hire Me
        </a>
      </nav>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-slate-300 hover:text-white transition-colors"
        aria-label="Toggle Menu"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </header>

  <main
    class="flex-grow w-full max-w-6xl mx-auto px-5 pt-4 pb-5 md:pt-28 md:pb-12 z-10"
  >
    <slot />
  </main>

  <footer
    class="w-full border-t border-slate-800/60 bg-black py-8 relative z-10"
  >
    <div
      class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <div
        class="flex flex-wrap justify-center items-center gap-2 sm:gap-3 text-slate-500 font-mono text-[10px] sm:text-xs uppercase tracking-widest text-center"
      >
        <span class="whitespace-nowrap">© 2026 Irfan Khattak</span>
        <span class="text-slate-700 hidden sm:inline">///</span>
        <span class="whitespace-nowrap">Karachi, Pakistan</span>
      </div>

      <div
        class="flex items-center gap-2 text-slate-500 font-mono text-xs sm:text-sm uppercase tracking-widest"
      >
        <span class="relative flex h-2 w-2 mr-1">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-60"
          ></span>
          <span
            class="relative inline-flex rounded-full h-1.8 w-1.8 bg-cyan-500"
          ></span>
        </span>
        All Systems Nominal
      </div>
    </div>
  </footer>
  <div
    id="mobile-overlay"
    class="fixed inset-0 bg-[#030712]/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"
  >
  </div>

  <div
    id="mobile-drawer"
    class="fixed top-0 right-0 h-full w-[280px] sm:w-[320px] bg-[#030712]/80 backdrop-blur-2xl border-l border-slate-700/50 z-50 transform translate-x-full transition-transform duration-300 ease-out shadow-[-20px_0_40px_rgba(0,0,0,0.7)] flex flex-col"
  >
    <div
      class="flex items-center justify-between p-6 border-b border-slate-800/60 bg-gradient-to-b from-white/[0.02] to-transparent"
    >
      <div class="flex items-center pl-2">
        <span
          class="text-sm font-semibold text-slate-200 uppercase tracking-widest"
          >Menu</span
        >
      </div>
      <button
        id="close-drawer-btn"
        aria-label="Close mobile menu"
        class="p-2 -mr-2 text-slate-400 hover:text-cyan-400 hover:rotate-90 transition-all duration-300 focus:outline-none"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path></svg
        >
      </button>
    </div>

    <nav class="flex flex-col p-5 mt-2 flex-grow overflow-y-auto h-full">
      <div class="flex flex-col gap-2">
        <a
          href="/"
          class="mobile-link group flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-cyan-500/10 border border-transparent hover:border-cyan-500/20 transition-all duration-300"
        >
          <div
            class="w-9 h-9 rounded-xl bg-slate-800/50 border border-slate-700/50 flex items-center justify-center text-slate-400 group-hover:text-cyan-400 group-hover:bg-cyan-500/20 group-hover:border-cyan-500/50 transition-all"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              ></path></svg
            >
          </div>
          <span
            class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors"
            >Home</span
          >
        </a>

        <a
          href="/#about"
          class="mobile-link group flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-emerald-500/10 border border-transparent hover:border-emerald-500/20 transition-all duration-300"
        >
          <div
            class="w-9 h-9 rounded-xl bg-slate-800/50 border border-slate-700/50 flex items-center justify-center text-slate-400 group-hover:text-emerald-400 group-hover:bg-emerald-500/20 group-hover:border-emerald-500/50 transition-all"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              ></path></svg
            >
          </div>
          <span
            class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors"
            >About</span
          >
        </a>

        <a
          href="/#projects"
          class="mobile-link group flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-purple-500/10 border border-transparent hover:border-purple-500/20 transition-all duration-300"
        >
          <div
            class="w-9 h-9 rounded-xl bg-slate-800/50 border border-slate-700/50 flex items-center justify-center text-slate-400 group-hover:text-purple-400 group-hover:bg-purple-500/20 group-hover:border-purple-500/50 transition-all"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg
            >
          </div>
          <span
            class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors"
            >Projects</span
          >
        </a>

        <a
          href="/#contact"
          class="mobile-link group flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-blue-500/10 border border-transparent hover:border-blue-500/20 transition-all duration-300"
        >
          <div
            class="w-9 h-9 rounded-xl bg-slate-800/50 border border-slate-700/50 flex items-center justify-center text-slate-400 group-hover:text-blue-400 group-hover:bg-blue-500/20 group-hover:border-blue-500/50 transition-all"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
          </div>
          <span
            class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors"
            >Contact</span
          >
        </a>
      </div>
      <div class="mt-auto flex flex-col gap-3 pt-8 pb-4">
        <div class="h-px w-full bg-slate-800/60 mb-2"></div>

        <a
          href="/#contact"
          class="mobile-link flex items-center justify-center w-full py-2.5 rounded-xl bg-cyan-500/10 text-cyan-400 border border-cyan-500/30 hover:bg-cyan-500/20 text-sm font-semibold transition-all shadow-[0_0_15px_rgba(34,211,238,0.1)]"
        >
          Hire Me
        </a>

        <a
          href="https://github.com/Irfan-code-cloud"
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-link flex items-center justify-center gap-2 w-full py-2.5 rounded-xl bg-slate-800/50 text-slate-300 border border-slate-700/50 hover:bg-slate-700 hover:text-white text-sm font-medium transition-all shadow-sm"
        >
          <svg
            class="w-4 h-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
          GitHub
        </a>
      </div>
    </nav>
    <div
      class="mt-auto p-6 border-t border-slate-800/60 bg-white/[0.02] backdrop-blur-md"
    >
      <div
        class="flex items-center gap-2 text-[10px] font-mono text-slate-400 uppercase tracking-[0.2em]"
      >
        <span
          class="w-2 h-2 rounded-full bg-cyan-400 shadow-[0_0_8px_rgba(34,211,238,0.8)] animate-pulse"
        ></span>
        System Online
      </div>
    </div>
  </div>

  <script>
    import "../scripts/home.ts";
  </script>
</html>
