---
// src/components/Terminal.astro
---

<div
    class="my-12 rounded-xl overflow-hidden border border-slate-800 bg-[#0a0f1a] shadow-2xl font-mono text-xs md:text-sm reveal-element opacity-0 translate-y-12 transition-all duration-1000 ease-out"
>
    <div
        class="bg-slate-900 px-4 py-2 flex items-center gap-2 border-b border-slate-800"
    >
        <div class="w-3 h-3 rounded-full bg-rose-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-emerald-500/80"></div>
        <span class="ml-2 text-slate-500 text-xs font-sans tracking-wide"
            >ciro-orchestrator-tty1</span
        >
    </div>

    <div class="p-5 h-[280px] overflow-y-auto" id="terminal-body">
        <div
            id="terminal-output"
            class="flex flex-col gap-1.5 mb-2 text-slate-300"
        >
            <div>
                <span class="text-emerald-400">system</span>: CIRO v2.1.0
                initialized.
            </div>
            <div>
                <span class="text-emerald-400">system</span>: Type '<span
                    class="text-white">help</span
                >' to see available commands.
            </div>
        </div>

        <div class="flex items-center gap-2 text-cyan-400 mt-2">
            <span>ikhattak@ciro:~$</span>
            <input
                type="text"
                id="terminal-input"
                class="flex-1 bg-transparent border-none outline-none text-slate-100 shadow-none focus:ring-0 p-0"
                autocomplete="off"
                spellcheck="false"
            />
        </div>
    </div>
</div>

<script>
    // Ensure the script runs on the client after the component mounts
    const input = document.getElementById("terminal-input") as HTMLInputElement;
    const output = document.getElementById("terminal-output");
    const body = document.getElementById("terminal-body");

    function printLine(html: string) {
        if (!output) return;
        const div = document.createElement("div");
        div.innerHTML = html;
        output.appendChild(div);
        if (body) body.scrollTop = body.scrollHeight; // Auto-scroll to bottom
    }

    const commands = {
        help: () =>
            'Available commands:<br>- <span class="text-amber-300">run ciro-agent --threat-level=high</span><br>- <span class="text-amber-300">clear</span>',
        clear: () => {
            if (output) output.innerHTML = "";
            return "";
        },
        "run ciro-agent --threat-level=high": async () => {
            if (input) input.disabled = true; // Lock input during execution

            printLine(
                '<span class="text-slate-400">Booting multi-agent orchestrator...</span>',
            );
            await new Promise((r) => setTimeout(r, 600));

            printLine(
                '<span class="text-blue-400">[INFO]</span> Connecting to Twilio ingestion pipeline... <span class="text-emerald-400">OK</span>',
            );
            await new Promise((r) => setTimeout(r, 800));

            printLine(
                '<span class="text-blue-400">[INFO]</span> Parsing threat matrix... <span class="text-rose-400">CRITICAL NODE DETECTED</span>',
            );
            await new Promise((r) => setTimeout(r, 800));

            printLine(
                '<span class="text-blue-400">[INFO]</span> Dispatching autonomous response agents to sectors 4, 7, and 9...',
            );
            await new Promise((r) => setTimeout(r, 800));

            if (input) {
                input.disabled = false;
                input.focus();
            }
            return '<span class="text-emerald-400">[SUCCESS]</span> Response orchestration complete. Latency: 42ms.';
        },
    };

    if (input) {
        input.addEventListener("keydown", async (e) => {
            if (e.key === "Enter") {
                const val = input.value.trim();
                input.value = "";
                if (!val) return;

                printLine(
                    `<div><span class="text-cyan-400 mt-2 block">ikhattak@ciro:~$</span> <span class="text-slate-100">${val}</span></div>`,
                );

                const action = commands[val as keyof typeof commands];
                if (action) {
                    const res = await action();
                    if (res) printLine(res as string);
                } else {
                    printLine(
                        `<span class="text-rose-400">bash: ${val}: command not found</span>`,
                    );
                }
            }
        });
    }
</script>
