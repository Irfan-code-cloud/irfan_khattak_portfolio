---
// src/components/GitHubStats.astro
import BentoCard from "./BentoCard.astro";

// We use the native fetch API to pull your live public data from GitHub
const response = await fetch("https://api.github.com/users/Irfan-code-cloud");
const data = await response.json();
---

<BentoCard title="Live Telemetry" href={data.html_url}>
    <div class="flex flex-col h-full justify-between">
        <p class="text-sm text-slate-400 mb-4 leading-relaxed">
            Real-time GitHub metrics. Actively contributing to open-source cloud
            architectures and mathematical optimization models.
        </p>

        <div class="flex flex-col gap-3 mt-auto">
            <div class="flex items-center gap-3 mb-2">
                <img
                    src={data.avatar_url}
                    alt="GitHub Avatar"
                    class="w-10 h-10 rounded-full border border-slate-700 shadow-md"
                />
                <div>
                    <p class="text-sm font-bold text-white tracking-tight">
                        @{data.login}
                    </p>
                    <p class="text-xs text-emerald-400 flex items-center gap-1">
                        <span
                            class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"
                        ></span>
                        System Online
                    </p>
                </div>
            </div>

            <div class="flex gap-2 text-xs font-mono">
                <span
                    class="bg-slate-950 text-slate-300 px-2 py-1 rounded border border-slate-800"
                >
                    Repos: <span class="text-cyan-400">{data.public_repos}</span
                    >
                </span>
                <span
                    class="bg-slate-950 text-slate-300 px-2 py-1 rounded border border-slate-800"
                >
                    Followers: <span class="text-blue-400"
                        >{data.followers}</span
                    >
                </span>
            </div>
        </div>
    </div>
</BentoCard>
