---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import BentoCard from "../components/BentoCard.astro";
---

<BaseLayout title="Home">
	<!-- ================= TOP SECTION: HERO (FULL SCREEN) ================= -->
	<!-- The section handles the full-screen height to keep the cards hidden below the fold -->
	<section
		class="w-full min-h-[calc(100vh-150px)] pt-2 md:pt-4 relative z-10"
	>
		<div
			class="w-full flex justify-center xl:hidden mb-8 opacity-0 translate-y-12 transition-all duration-[800ms] ease-out scroll-reveal"
		>
			<div
				class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-slate-900 border border-slate-800 text-xs font-extralight text-white/70 tracking-wide shadow-sm"
			>
				<span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"
				></span>
				Based in Karachi, Pakistan
			</div>
		</div>

		<div
			class="flex flex-col-reverse xl:flex-row gap-8 xl:gap-12 items-center xl:items-start justify-between w-full"
		>
			<div
				class="flex-1 space-y-5 text-center xl:text-left opacity-0 translate-y-12 transition-all duration-[800ms] ease-out scroll-reveal"
			>
				<div>
					<div
						class="hidden xl:inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-slate-900 border border-slate-800 text-sm font-extralight text-white/70 tracking-wide leading-relaxed mb-10 w-fit shadow-sm"
					>
						<span
							class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"
						></span>
						Based in Karachi, Pakistan
					</div>

					<div
						class="flex items-center justify-center xl:justify-start w-full mb-4 sm:mb-6 xl:mb-8"
					>
						<h1
							class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-normal tracking-tight text-white bg-gradient-to-br from-white via-slate-200 to-slate-500 bg-clip-text text-transparent leading-tight w-full"
						>
							<span id="typewriter"></span><span
								class="w-[3px] h-[0.9em] bg-cyan-400 ml-1.5 animate-pulse inline-block align-baseline rounded-full"
							></span>
						</h1>
					</div>

					<p
						class="text-sm sm:text-base lg:text-lg text-white/70 tracking-wide leading-relaxed max-w-lg mx-auto xl:mx-0 font-light [text-wrap:balance]"
					>
						I architect scalable <strong
							class="font-semibold text-white tracking-wide"
							><i>Full-Stack Systems</i></strong
						> and engineer <strong
							class="font-semibold text-white tracking-wide"
							><i>Autonomous AI Workflows</i></strong
						>.<span class="hidden md:inline">
							From intelligent data pipelines to cloud
							infrastructure, I build high-performance solutions
							that solve complex operational bottlenecks.</span
						>
					</p>
				</div>

				<!-- Large CTA Buttons -->
				<div
					class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center justify-center xl:justify-start gap-3 sm:gap-4 pt-2 sm:pt-4 mt-0 sm:mt-2 w-full"
				>
					<a
						href="#projects"
						class="flex items-center justify-center w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-3.5 text-sm sm:text-base rounded-xl bg-cyan-500/10 text-cyan-400 border border-cyan-500/30 font-normal shadow-[0_0_10px_rgba(34,211,238,0.08)] transition-all duration-300 hover:bg-cyan-500/15 hover:border-cyan-400/50 hover:-translate-y-0.5 hover:shadow-[0_0_15px_rgba(34,211,238,0.2)]"
					>
						Explore My Work
					</a>
					<a
						href="/Irfan_Khattak_CV.pdf"
						download="Irfan_Khattak_CV.pdf"
						class="group flex items-center justify-center w-full sm:w-auto gap-2.5 px-6 sm:px-8 py-3 sm:py-3.5 text-sm sm:text-base rounded-xl bg-slate-800/50 text-white/70 tracking-wide border border-slate-700 font-normal backdrop-blur-sm shadow-sm transition-all duration-300 hover:bg-slate-700 hover:text-white hover:border-slate-500 hover:-translate-y-0.5 hover:shadow-md"
					>
						Download CV
						<svg
							class="w-4 h-4 group-hover:translate-y-0.5 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
							></path>
						</svg>
					</a>
				</div>
			</div>

			<!-- Right Column: The Visuals & Orbit -->
			<div
				class="relative w-full max-w-[180px] sm:max-w-[260px] md:max-w-[320px] xl:max-w-[360px] mx-auto opacity-0 translate-y-12 transition-all duration-[800ms] delay-200 ease-out scroll-reveal shrink-0"
			>
				<div
					class="aspect-[4/5] rounded-3xl overflow-hidden border border-slate-700/50 shadow-2xl relative z-10 group"
				>
					<img
						src="/profile.jpeg"
						alt="Irfan Khattak"
						class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
					/>
					<div
						class="absolute inset-0 bg-gradient-to-t from-[#030712] via-transparent to-transparent opacity-80 pointer-events-none"
					>
					</div>
				</div>

				<div class="hidden md:block absolute -bottom-4 -right-4 z-20">
					<div
						class="bg-slate-900/90 p-2.5 rounded-xl border border-slate-700 backdrop-blur-xl shadow-2xl flex items-center gap-2.5 hover:border-cyan-500/50 hover:-translate-y-0.5 transition-all cursor-default"
					>
						<div
							class="w-7 h-7 rounded-full bg-cyan-500/20 flex items-center justify-center text-cyan-400 font-mono text-[10px] font-medium border border-cyan-500/30 shrink-0"
						>
							AI
						</div>
						<div class="text-left shrink-0">
							<p
								class="text-[8px] text-slate-500 uppercase tracking-wider"
							>
								Current Stack
							</p>
							<p
								class="text-[10px] text-white/70 tracking-wide leading-relaxed font-semibold"
							>
								Python & GCP
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<div class="relative w-full max-w-5xl mx-auto mt-16">
		<div
			class="h-px w-full bg-gradient-to-r from-transparent via-slate-800 to-transparent"
		>
		</div>
		<div
			class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1/3 h-[2px] bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent blur-[2px]"
		>
		</div>
	</div>
	<!-- ================= BOTTOM SECTION: ABOUT & TERMINAL CARDS ================= -->
	<section id="about" class="w-full pt-16 pb-20 relative z-10">
		<div
			class="absolute inset-0 w-[100vw] left-1/2 -translate-x-1/2 bg-[#050914] -z-10"
		>
		</div>
		<!-- NEW: Section Header -->
		<div
			class="flex flex-col items-center justify-center text-center mb-16 w-full max-w-6xl mx-auto"
		>
			<div
				class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-[10px] md:text-xs font-mono uppercase tracking-widest mb-4"
			>
				<svg
					class="w-3.5 h-3.5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg
				>
				Developer Profile
			</div>
			<h2
				class="text-2xl sm:text-3xl md:text-4xl font-normal text-white tracking-tight"
			>
				The architecture behind the engineer.
			</h2>
		</div>

		<!-- Changed to a 50/50 grid (grid-cols-2) for perfect symmetry -->
		<div
			class="grid grid-cols-1 lg:grid-cols-2 gap-8 w-full max-w-6xl mx-auto items-stretch"
		>
			<!-- 1. ABOUT CARD -->
			<div
				class="group relative p-4 sm:p-6 md:p-8 rounded-2xl bg-slate-900/40 border border-slate-800/60 backdrop-blur-md shadow-xl flex flex-col h-full overflow-hidden transition-all duration-500 hover:border-slate-700 hover:shadow-[0_0_30px_rgba(34,211,238,0.05)] opacity-0 translate-y-12 transition-all duration-[800ms] ease-out scroll-reveal"
			>
				<!-- Subtle background glow that reacts to hover -->
				<div
					class="absolute -top-24 -right-24 w-48 h-48 bg-cyan-500/10 rounded-full blur-3xl group-hover:bg-cyan-500/20 transition-all duration-700"
				>
				</div>

				<div class="relative z-10 flex flex-col">
					<div class="space-y-6">
						<div
							class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 sm:gap-4"
						>
							<div class="flex items-center gap-3">
								<div
									class="w-10 h-10 rounded-full bg-slate-800/80 border border-slate-700 flex items-center justify-center shrink-0"
								>
									<svg
										class="w-5 h-5 text-cyan-400"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
										><path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="1.5"
											d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
										></path></svg
									>
								</div>
								<h3
									class="text-xl font-medium text-slate-100 tracking-tight"
								>
									Lead Systems Engineer
								</h3>
							</div>
							<div
								class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] sm:text-xs font-medium shrink-0"
							>
								<span class="relative flex h-2 w-2">
									<span
										class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
									></span>
									<span
										class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
									></span>
								</span>
								Seeking Remote Roles
							</div>
						</div>

						<p
							class="text-sm md:text-base text-white/70 tracking-wide leading-relaxed leading-relaxed font-extralight"
						>
							I specialize in <strong
								class="font-medium text-slate-200"
								>backend architecture</strong
							>, <strong class="font-medium text-slate-200"
								>cloud infrastructure</strong
							>, and AI orchestration, building scalable systems
							that bridge complex operational challenges and
							technical execution.
						</p>

						<p
							class="text-sm md:text-base text-white/70 tracking-wide leading-relaxed leading-relaxed font-extralight"
						>
							My recent work focuses on serverless logistics tools
							and agentic AI pipelines, including end-to-end
							platforms like CIRO and the Karachi Fleet Optimizer.
						</p>

						<div>
							<p
								class="text-xs text-slate-500 uppercase tracking-widest font-semibold mb-3"
							>
								Core Stack
							</p>
							<div class="flex flex-wrap gap-2">
								<span
									class="px-3 py-1 text-xs font-mono rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20"
									>Python</span
								>
								<span
									class="px-3 py-1 text-xs font-mono rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20"
									>FastAPI</span
								>
								<span
									class="px-3 py-1 text-xs font-mono rounded-full bg-green-500/10 text-green-400 border border-green-500/20"
									>Node.js</span
								>
								<span
									class="px-3 py-1 text-xs font-mono rounded-full bg-rose-500/10 text-rose-400 border border-rose-500/20"
									>GCP & Vertex AI</span
								>
								<span
									class="px-3 py-1 text-xs font-mono rounded-full bg-cyan-500/10 text-cyan-400 border border-cyan-500/20"
									>React & Astro</span
								>
							</div>
						</div>
					</div>
					<div
						class="mt-8 pt-6 border-t border-slate-800/60 flex flex-col sm:flex-row items-stretch sm:items-center gap-3"
					>
						<a
							href="https://www.skills.google/public_profiles/13f718f2-0013-4c74-a0b4-f67b30a48dfb"
							target="_blank"
							rel="noopener noreferrer"
							class="group inline-flex items-center justify-center w-full sm:w-auto gap-2 px-4 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-white/70 tracking-wide leading-relaxed hover:bg-slate-700 hover:text-white hover:border-slate-500 hover:-translate-y-0.5 transition-all duration-300 text-xs font-normal shadow-md"
						>
							Verified GCP Badges
							<svg
								class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
								></path>
							</svg>
						</a>

						<a
							href="https://www.credly.com/users/irfan-khattak.0d8db4bb"
							target="_blank"
							rel="noopener noreferrer"
							class="group inline-flex items-center justify-center w-full sm:w-auto gap-2 px-4 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-white/70 tracking-wide leading-relaxed hover:bg-slate-700 hover:text-white hover:border-slate-500 hover:-translate-y-0.5 transition-all duration-300 text-xs font-normal shadow-md"
						>
							Verified Badges on Credly
							<svg
								class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
								></path>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<!-- 2. TERMINAL JSON CARD -->
			<div
				class="rounded-xl bg-black border border-slate-800 shadow-2xl font-mono text-xs md:text-sm overflow-hidden flex flex-col h-full opacity-0 translate-y-12 transition-all duration-[800ms] delay-200 ease-out scroll-reveal"
			>
				<div
					class="bg-[#202124] px-4 py-2 flex items-center justify-between border-b border-slate-800"
				>
					<div class="flex items-center gap-2">
						<svg
							class="w-4 h-4 text-white/70 tracking-wide leading-relaxed"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M8 9l3 3-3 3m5 0h3M4 17h16a2 2 0 002-2V5a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"
							></path>
						</svg>
						<span
							class="text-white/70 tracking-wide leading-relaxed text-xs font-sans tracking-wide"
							>irfan@cloudshell:~</span
						>
					</div>
					<div class="flex gap-1.5">
						<div class="w-2.5 h-2.5 rounded-full bg-slate-600">
						</div>
						<div class="w-2.5 h-2.5 rounded-full bg-slate-600">
						</div>
						<div class="w-2.5 h-2.5 rounded-full bg-slate-600">
						</div>
					</div>
				</div>

				<div
					id="terminal-container"
					class="p-4 sm:p-6 md:p-8 text-white/70 tracking-wide leading-relaxed leading-relaxed flex-1 flex flex-col justify-start"
				>
					<div class="flex items-center">
						<span class="text-emerald-400">irfan@cloudshell</span
						>:<span class="text-blue-400">~</span>$
						<span id="term-cmd" class="ml-2 text-white"></span>
						<span
							id="term-cursor-1"
							class="inline-block w-2.5 h-4 bg-slate-300 ml-1 animate-terminal-blink"
						></span>
					</div>

					<div
						id="term-output"
						class="mt-4 opacity-0 transition-opacity duration-300 overflow-x-auto pb-2 scrollbar-hide whitespace-nowrap"
					>
						<span class="text-white">&#123;</span><br />
						&nbsp;&nbsp;<span class="text-blue-300">"name"</span>: <span
							class="text-emerald-300">"Irfan Khattak"</span
						>,<br />
						&nbsp;&nbsp;<span class="text-blue-300"
							>"education"</span
						>: <span class="text-emerald-300"
							>"Virtual University"</span
						>,<br />
						&nbsp;&nbsp;<span class="text-blue-300"
							>"downtime_mode"</span
						>: <span class="text-white">&#123;</span><br />
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-blue-300"
							>"favorite_shows"</span
						>: <span class="text-white">[</span><br />
						&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span
							class="text-emerald-300">"Breaking Bad"</span
						>, <span class="text-emerald-300">"Dexter"</span>, <span
							class="text-emerald-300">"Weak Hero"</span
						>,<br />
						&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span
							class="text-emerald-300">"The Vampire Diaries"</span
						>, <span class="text-emerald-300">"YOU"</span><br />
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-white">]</span
						>,<br />
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-blue-300"
							>"favorite_movies"</span
						>: <span class="text-white">[</span><br />
						&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span
							class="text-emerald-300"
							>"Silence of the Lambs"</span
						>, <span class="text-emerald-300">"Fractured"</span>,<br
						/>
						&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span
							class="text-emerald-300">"Fight Club"</span
						>, <span class="text-emerald-300">"Predestination"</span
						>,<br />
						&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span
							class="text-emerald-300">"Obsession 2026"</span
						>, <span class="text-emerald-300"
							>"The Sixth Sense"</span
						><br />
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-white">]</span
						><br />
						&nbsp;&nbsp;<span class="text-white">&#125;</span><br />
						<span class="text-white">&#125;</span>
					</div>
					<div
						id="term-prompt-2"
						class="mt-2 flex items-center opacity-0 transition-opacity duration-300"
					>
						<span class="text-emerald-400">irfan@cloudshell</span
						>:<span class="text-blue-400">~</span>$ <span
							class="inline-block w-2.5 h-4 bg-slate-300 ml-1.5 animate-terminal-blink"
						></span>
					</div>
				</div>
			</div>
		</div>

		<!-- Github Contributions Graph -->
		<div
			class="w-full max-w-6xl mx-auto mt-8 opacity-0 translate-y-12 transition-all duration-[800ms] delay-[400ms] ease-out scroll-reveal"
		>
			<div
				class="p-4 sm:p-6 md:p-8 rounded-2xl bg-black border border-white/20 shadow-xl flex flex-col gap-6"
			>
				<div class="flex items-center justify-between">
					<div class="flex items-center gap-3">
						<div
							class="w-10 h-10 rounded-full bg-[#111] flex items-center justify-center border border-white/10 text-white"
						>
							<svg
								viewBox="0 0 24 24"
								class="w-5 h-5 fill-current"
								aria-hidden="true"
								><path
									d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
								></path></svg
							>
						</div>
						<div>
							<h3
								class="text-base font-medium text-white tracking-tight flex items-center gap-2"
							>
								Live Contribution Telemetry
								<span class="relative flex h-2 w-2">
									<span
										class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
									></span>
									<span
										class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
									></span>
								</span>
							</h3>
							<p class="text-xs text-gray-400 font-mono">
								github.com/Irfan-code-cloud
							</p>
						</div>
					</div>
					<div
						class="hidden md:block text-xs font-mono text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-full"
					>
						System Online
					</div>
